{
  "manifest_version": 3,
  "name": "Context-Aware Notifier",
  "description": "Tracks browser activity and adapts notification delivery.",
  "version": "0.1.0",
  "permissions": ["tabs", "idle", "storage", "alarms"],
  "host_permissions": ["http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
